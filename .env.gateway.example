# Copy to .env.gateway and fill in your values.
# .env.gateway is gitignored — never commit real credentials.

# ── Walacor backend storage ──────────────────────────────────────────────────
WALACOR_SERVER=https://sandbox.walacor.com/api
WALACOR_USERNAME=your-username
WALACOR_PASSWORD=your-password

# ── Governance mode ──────────────────────────────────────────────────────────
# Set to true to disable governance and run as transparent proxy.
# WALACOR_SKIP_GOVERNANCE=false

# ── Tenant identity ──────────────────────────────────────────────────────────
WALACOR_GATEWAY_TENANT_ID=your-tenant-id

# ── LLM provider credentials (set whichever you use) ────────────────────────
# WALACOR_PROVIDER_OPENAI_KEY=sk-...
# WALACOR_PROVIDER_ANTHROPIC_KEY=sk-ant-...
# WALACOR_PROVIDER_OLLAMA_URL=http://localhost:11434

# ── Caller authentication (comma-separated) ─────────────────────────────────
# WALACOR_GATEWAY_API_KEYS=key1,key2

# ── Remote control plane (fleet mode — optional) ────────────────────────────
# Only needed when connecting to a remote/primary gateway for fleet sync.
# When omitted, the embedded control plane manages state locally.
# WALACOR_CONTROL_PLANE_URL=https://primary-gateway:8000
# WALACOR_CONTROL_PLANE_API_KEY=your-cp-api-key

# ── Embedded control plane (Phase 20) ───────────────────────────────────────
# WALACOR_CONTROL_PLANE_ENABLED=true
# WALACOR_CONTROL_PLANE_DB_PATH=              # default: alongside WAL db

# ── Lineage dashboard (Phase 18) ────────────────────────────────────────────
# WALACOR_LINEAGE_ENABLED=true

# ── Multi-model routing + Redis (Phase 15) ──────────────────────────────────
# WALACOR_REDIS_URL=redis://redis-svc:6379/0
# WALACOR_MODEL_ROUTING_JSON=[{"pattern":"qwen3*","provider":"ollama","url":"http://localhost:11434"}]

# ── Tool-aware gateway (Phase 14/16) ────────────────────────────────────────
# WALACOR_TOOL_AWARE_ENABLED=false
# WALACOR_WEB_SEARCH_ENABLED=false
# WALACOR_MCP_SERVERS_JSON=

# ── Thinking strip (Phase 17) ───────────────────────────────────────────────
# WALACOR_THINKING_STRIP_ENABLED=true

# ── Llama Guard (Phase 17) ──────────────────────────────────────────────────
# WALACOR_LLAMA_GUARD_ENABLED=false

# ── OpenTelemetry (Phase 17) ────────────────────────────────────────────────
# WALACOR_OTEL_ENABLED=false
# WALACOR_OTEL_ENDPOINT=http://localhost:4317

# ── Token budget ─────────────────────────────────────────────────────────────
# WALACOR_TOKEN_BUDGET_ENABLED=false
# WALACOR_TOKEN_BUDGET_MAX_TOKENS=1000000
# WALACOR_TOKEN_BUDGET_PERIOD=monthly

# ── Session integrity chain ─────────────────────────────────────────────────
# WALACOR_SESSION_CHAIN_ENABLED=true

# ── Observability ────────────────────────────────────────────────────────────
# WALACOR_LOG_LEVEL=INFO
# WALACOR_METRICS_ENABLED=true

# ── Server ───────────────────────────────────────────────────────────────────
# WALACOR_GATEWAY_HOST=0.0.0.0
# WALACOR_GATEWAY_PORT=8000
